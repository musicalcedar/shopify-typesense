# Shopify
SHOPIFY_STORE=tu-tienda.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# Typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your-secret-api-key

# Docker (solo desarrollo local — no aplica en Railway)
TYPESENSE_DOCKER_VOLUME=typesense-data
TYPESENSE_DOCKER_IMAGE=typesense/typesense:27.0

# Railway / Server
# PORT=3000                    # Railway lo inyecta automáticamente
# SYNC_SECRET=your-sync-secret # Protege el endpoint POST /sync
# RAILWAY_ENVIRONMENT=production # Railway lo inyecta automáticamente
